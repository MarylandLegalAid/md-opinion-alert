# Copy to .env for local development. On Render these are service env vars.

# Core
DJANGO_SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://mdoa:mdoa@localhost:5432/mdoa

# Entra OIDC (see docs/entra-setup.md). Leave unset until the app
# registration exists; dev login covers local work in the meantime.
#OIDC_RP_CLIENT_ID=
#OIDC_RP_CLIENT_SECRET=
#ENTRA_TENANT_ID=
#ADMIN_APP_ROLE=Admin

# Force-enable/disable flags (defaults: OIDC on when client id set,
# dev login on when DEBUG)
#OIDC_ENABLED=false
#DEV_LOGIN_ENABLED=true

# Scraper identity — set a real contact address so mdcourts.gov can reach you
#SCRAPER_CONTACT_EMAIL=contact@example.org
#SCRAPER_USER_AGENT=MD-Opinion-Alert/1.0 (appellate opinion monitor; +mailto:contact@example.org)
#BACKFILL_START_YEAR=2024

# Email transport: console (default) | smtp | acs | graph
#EMAIL_BACKEND_CHOICE=console
#DEFAULT_FROM_EMAIL=alerts@example.org
#SITE_URL=https://md-opinion-web.onrender.com
# ACS (service principal; SDK reads AZURE_* from env)
#ACS_ENDPOINT=https://<resource>.communication.azure.com
#ACS_SENDER_ADDRESS=alerts@org.example
#AZURE_CLIENT_ID=
#AZURE_TENANT_ID=
#AZURE_CLIENT_SECRET=
# Graph alternative (shared mailbox with application Mail.Send)
#GRAPH_SENDER_ADDRESS=shared@org.example
